# ==================== NEURAL CARE CONFIGURATION ====================
# Copy this file to .env and fill in your values

# -------------------- SERVER --------------------
PORT=3000
NODE_ENV=production

# -------------------- MONGODB --------------------
# MongoDB Atlas (Cloud - Recommended for hosting):
# Get free MongoDB at: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/neuralcare

# Or use MongoDB locally:
MONGODB_URI=mongodb://localhost:27017/neuralcare

